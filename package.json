{
  "name": "crm-electron-app",
  "version": "1.0.0",
  "description": "Exemplo simples de app Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "lint": "node -e \"console.log('Lint não configurado')\"",
    "test": "node -e \"console.log('Testes não configurados')\""
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.example.crm-electron-app",
    "productName": "CRMElectronApp",
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ]
  }
}
