{
  "name": "crm-electron-app",
  "version": "0.0.22",
  "description": "App de Recomendações de Produtos",
  "author": "CRM Team Farmarcas <uelinton.martins@terceirizados.farmarcas.com.br>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "lint": "node -e \"console.log('Lint não configurado')\"",
    "test": "node -e \"console.log('Testes não configurados')\""
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "br.com.farmarcas.crm-electron-app",
    "productName": "CRM Radar",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": true,
      "icon": "assets/icon.ico",
      "artifactName": "CRM-Radar-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CRM Radar",
      "uninstallDisplayName": "CRM Radar",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": "LICENSE.txt"
    },
    "publish": {
      "provider": "github",
      "owner": "farmarcas",
      "repo": "crm-electron-app",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "executableName": "CRM Radar",
      "target": [
        "deb",
        "rpm"
      ],
      "icon": "assets",
      "extraFiles": [
        {
          "from": "scripts/linux-install-autostart.sh",
          "to": "linux-install-autostart.sh"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "assets/**/*",
      "node_modules/electron-log/**/*",
      "node_modules/electron-updater/**/*"
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
